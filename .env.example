# Supabase — project URL + service role (server only) + anon (client sign-in via server)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_key

# Resend — verified sender domain required in dashboard
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Skills <noreply@yourdomain.com>

# Site admin panel (single shared password — not tied to Supabase users)
ADMIN_SITE_PASSWORD=choose_a_long_random_password
ADMIN_JWT_SECRET=another_long_random_secret

# Daily cycle rollover (timezone for 06:00 boundary)
CYCLE_TIMEZONE=Asia/Kolkata

# Optional: Gemini mentor
GEMINI_API_KEY=

NODE_ENV=development
