{
  "workflow_name": "S-KILLING IT: 7-Day Sprint + 76-Day Master Curriculum",
  "version": "1.0",
  "created": "2026-04-20",
  "description": "Automated curriculum delivery, tracking, quiz grading, and reward system for engineering students",
  "target_audience": "First-year engineering students, all disciplines",
  "total_duration_days": 76,
  "content_delivery_per_day_minutes": 60,
  "automation_platform": "Antigravity",

  "workflow_triggers": [
    {
      "id": "trigger_daily_content_release",
      "name": "Daily Content Release",
      "type": "time-based",
      "schedule": "Daily at user's selected time (6 AM / 12 PM / 6 PM)",
      "actions": [
        {
          "action_id": "send_discord_notification",
          "platform": "Discord",
          "message": "🎯 Your daily lesson is live! {{day_name}} - {{lesson_title}}. {{video_link}}",
          "channel": "general"
        },
        {
          "action_id": "send_email_notification",
          "platform": "Email",
          "template": "daily_lesson_email",
          "fields": ["lesson_title", "video_url", "project_brief", "resources"]
        },
        {
          "action_id": "publish_to_dashboard",
          "platform": "Web Dashboard",
          "content_type": "lesson_page",
          "visibility": "student"
        },
        {
          "action_id": "log_content_release",
          "database": "learning_analytics",
          "fields": ["student_id", "day_number", "timestamp", "content_type"]
        }
      ],
      "condition": "Student enrolled in curriculum AND content available for day"
    },

    {
      "id": "trigger_lesson_completion",
      "name": "Lesson Completion",
      "type": "event-based",
      "events": [
        "video_watched_75_percent",
        "project_submitted",
        "code_deployed_live"
      ],
      "actions": [
        {
          "action_id": "mark_lesson_complete",
          "database": "student_progress",
          "fields": ["student_id", "day_number", "completion_date", "completion_time"]
        },
        {
          "action_id": "award_xp_points",
          "system": "gamification",
          "calculation": "base_xp + (bonus_xp if deployed)",
          "notification": "You earned {{xp_earned}} XP! 🎯"
        },
        {
          "action_id": "update_dashboard_progress",
          "display": "progress_bar",
          "value": "days_completed / total_days"
        },
        {
          "action_id": "check_quiz_availability",
          "condition": "if day % 7 == 0",
          "action_if_true": "unlock_weekly_quiz"
        }
      ]
    },

    {
      "id": "trigger_weekly_quiz",
      "name": "Weekly Quiz Release & Grading",
      "type": "time-based",
      "schedule": "Friday 6 PM, due Sunday 11:59 PM",
      "actions": [
        {
          "action_id": "release_quiz",
          "platform": "Quiz Engine",
          "questions_count": 40,
          "question_mix": {
            "multiple_choice": "40%",
            "code_reading": "30%",
            "short_answer": "20%",
            "code_submission": "10%"
          },
          "time_limit_minutes": 45,
          "notification": "📋 Your weekly quiz for Week {{week_number}} is now available!"
        },
        {
          "action_id": "auto_grade_quiz",
          "trigger": "quiz_submitted",
          "grade_types": {
            "multiple_choice": "instant",
            "code_reading": "instant",
            "short_answer": "human_review_24h",
            "code_submission": "automated_test"
          }
        },
        {
          "action_id": "unlock_next_week_logic",
          "scoring_rules": {
            "0_50_percent": "send_retry_materials, offer_office_hours, retry_in_48h",
            "51_70_percent": "unlock_next_week, send_improvement_suggestions",
            "71_85_percent": "unlock_next_week_plus_basics, send_encouragement",
            "86_100_percent": "unlock_next_week_plus_bonus, tag_for_advanced_track"
          }
        },
        {
          "action_id": "award_certificate",
          "trigger": "score >= 70",
          "certificate_type": "Week {{week_number}} Completion",
          "delivery": ["email", "dashboard", "discord_announcement"]
        }
      ]
    },

    {
      "id": "trigger_leaderboard_update",
      "name": "Leaderboard Auto-Update",
      "type": "time-based",
      "schedule": "Daily at midnight UTC",
      "actions": [
        {
          "action_id": "calculate_rankings",
          "ranking_criteria": [
            { "field": "projects_completed", "weight": 40 },
            { "field": "quiz_average_score", "weight": 30 },
            { "field": "total_xp_points", "weight": 20 },
            { "field": "days_streak", "weight": 10 }
          ]
        },
        {
          "action_id": "generate_leaderboard_json",
          "output": "/data/leaderboard.json",
          "include_fields": ["rank", "name", "projects_completed", "quiz_score", "xp_points", "streak_days", "badges"]
        },
        {
          "action_id": "post_to_discord",
          "channel": "leaderboard",
          "message_format": "embed",
          "include_top_n": 10,
          "refresh_frequency": "daily"
        },
        {
          "action_id": "update_web_dashboard",
          "component": "leaderboard_widget",
          "real_time_sync": true
        },
        {
          "action_id": "check_milestone_achievements",
          "milestones": [
            { "condition": "rank == 1", "action": "award_platinum_badge" },
            { "condition": "rank <= 5", "action": "award_gold_badge" },
            { "condition": "rank <= 10", "action": "award_silver_badge" }
          ]
        }
      ]
    },

    {
      "id": "trigger_badge_rewards",
      "name": "Badge & Certificate Auto-Generation",
      "type": "event-based",
      "events": [
        "milestone_achieved",
        "quiz_passed",
        "project_deployed",
        "streak_reached",
        "week_completed"
      ],
      "actions": [
        {
          "action_id": "generate_badge",
          "badge_engine": "dynamic_image_generator",
          "template_variables": ["student_name", "badge_name", "achievement_date", "rank"],
          "output_format": "PNG",
          "storage": "cloud_cdn"
        },
        {
          "action_id": "send_achievement_email",
          "template": "achievement_email",
          "include_attachment": "badge_png"
        },
        {
          "action_id": "post_to_discord",
          "channel": "achievements",
          "message": "🎉 {{student_name}} earned {{badge_name}}! {{badge_image}}",
          "add_role": "badge_specific_discord_role"
        },
        {
          "action_id": "update_student_profile",
          "add_to_collection": "badges",
          "fields": ["badge_id", "earned_date", "achievement_description"]
        }
      ]
    },

    {
      "id": "trigger_streak_tracker",
      "name": "Daily Streak Tracking & Notifications",
      "type": "time-based",
      "schedule": "Every 6 hours",
      "actions": [
        {
          "action_id": "check_daily_completion",
          "metric": "lesson_completed_today",
          "timezone": "student_local_timezone"
        },
        {
          "action_id": "update_streak_counter",
          "logic": {
            "if_completed_today": "increment_streak, reset_missed_days",
            "if_not_completed_and_within_24h": "no_action",
            "if_not_completed_after_24h": "break_streak, send_reset_notification"
          }
        },
        {
          "action_id": "streak_milestone_check",
          "milestones": [
            { "days": 3, "reward": "50_xp, on_fire_badge" },
            { "days": 7, "reward": "100_xp, unstoppable_badge" },
            { "days": 30, "reward": "500_xp, month_master_certificate" },
            { "days": 76, "reward": "1000_xp, industry_ready_builder_certificate" }
          ]
        },
        {
          "action_id": "send_streak_reminder",
          "condition": "not_completed_in_last_12_hours",
          "message": "⏰ Don't break your {{streak_days}}-day streak! Complete today's lesson.",
          "platforms": ["discord", "email", "whatsapp"]
        }
      ]
    },

    {
      "id": "trigger_discord_bot_commands",
      "name": "Discord Bot Command Handler",
      "type": "event-based",
      "event": "discord_message_starts_with_exclamation",
      "commands": [
        {
          "command": "!progress",
          "description": "Show student's completion percentage",
          "response": "Embed with progress bar, XP, badges, next lesson"
        },
        {
          "command": "!leaderboard",
          "description": "Show top 10 students",
          "response": "Embed with rankings, XP, streak days"
        },
        {
          "command": "!help [topic]",
          "description": "Get resources for a topic",
          "response": "Links to docs, tutorials, example code"
        },
        {
          "command": "!submit [project_url]",
          "description": "Submit project for review",
          "response": "Confirmation + auto-tag reviewers in thread"
        },
        {
          "command": "!grade [submission_id]",
          "description": "Reviewer grades a submission",
          "response": "Score recorded, student notified, XP awarded"
        },
        {
          "command": "!streak",
          "description": "Show current streak",
          "response": "Display streak count + milestone progress"
        },
        {
          "command": "!quiz",
          "description": "Get link to current week's quiz",
          "response": "Quiz link + deadline + score if completed"
        },
        {
          "command": "!next",
          "description": "Show what's coming next",
          "response": "Next 3 lessons preview + due dates"
        }
      ],
      "new_member_automation": {
        "trigger": "member_joins_server",
        "actions": [
          "send_welcome_dm_with_onboarding_video",
          "assign_student_role",
          "add_to_cohort_channel",
          "schedule_intro_call_with_mentor"
        ]
      },
      "inactive_user_automation": {
        "trigger": "3_days_without_lesson_completion",
        "action": "send_gentle_reminder_dm_with_encouragement_link"
      }
    },

    {
      "id": "trigger_project_review_cycle",
      "name": "Automated Project Review & Feedback",
      "type": "event-based",
      "event": "project_submitted",
      "actions": [
        {
          "action_id": "automated_checks",
          "checks": [
            "code_deploys_without_error",
            "readme_exists_and_complete",
            "github_repo_properly_formatted",
            "no_obvious_bugs"
          ]
        },
        {
          "action_id": "assign_peer_reviewers",
          "logic": "find_2_students_same_cohort_different_timezone",
          "notification": "Discord @mention + email with review rubric"
        },
        {
          "action_id": "collect_peer_feedback",
          "rubric_categories": [
            "code_quality (1-5)",
            "functionality (1-5)",
            "creativity (1-5)",
            "documentation (1-5)"
          ],
          "form_type": "structured_form_with_text_comments"
        },
        {
          "action_id": "aggregate_scores",
          "calculation": "average of peer scores + automated checks bonus",
          "result_range": "0-100"
        },
        {
          "action_id": "send_feedback_to_student",
          "delivery": "email + discord + dashboard",
          "format": "constructive, actionable comments"
        },
        {
          "action_id": "update_portfolio",
          "add_project": {
            "title": "project_name",
            "description": "student_description",
            "score": "peer_review_score",
            "link": "github_url",
            "tech_stack": "parsed_from_readme",
            "peer_feedback": "summarized_comments"
          }
        }
      ]
    },

    {
      "id": "trigger_weekly_analytics_summary",
      "name": "Weekly Student Analytics & Report",
      "type": "time-based",
      "schedule": "Sunday 6 PM",
      "actions": [
        {
          "action_id": "compile_weekly_stats",
          "metrics": [
            "lessons_completed",
            "projects_deployed",
            "quiz_score",
            "xp_earned",
            "streak_status",
            "peer_review_score_average",
            "ranking_change"
          ]
        },
        {
          "action_id": "send_weekly_recap_email",
          "template": "weekly_summary",
          "include": [
            "achievements_this_week",
            "projects_built",
            "skills_learned",
            "ranking_position",
            "next_week_preview"
          ],
          "tone": "celebratory_and_motivating"
        },
        {
          "action_id": "identify_struggling_students",
          "condition": "lesson_completion < 50% OR quiz_score < 60%",
          "action": "flag_for_mentor_outreach"
        },
        {
          "action_id": "identify_top_performers",
          "condition": "quiz_score >= 90% AND projects_deployed >= 2",
          "action": "invite_to_advanced_track"
        }
      ]
    },

    {
      "id": "trigger_content_unlock_logic",
      "name": "Conditional Content Unlock",
      "type": "event-based",
      "event": "quiz_submitted_and_graded",
      "logic": {
        "if_score_gte_70": {
          "action": "unlock_next_week_content",
          "notification": "Congrats! Week {{next_week}} is now open!",
          "send_week_overview": "email"
        },
        "if_score_lt_70": {
          "action": "send_retry_preparation",
          "include": [
            "review_materials_for_weak_topics",
            "link_to_mentor_office_hours",
            "offer_peer_study_group",
            "retry_quiz_in_48_hours"
          ]
        },
        "if_score_gte_85": {
          "action": "unlock_bonus_advanced_content",
          "bonus": "advanced_challenges, optional_deep_dive_projects"
        }
      }
    },

    {
      "id": "trigger_mentor_assignment",
      "name": "Mentor Auto-Assignment & Pairing",
      "type": "time-based",
      "schedule": "First day of enrollment + weekly check-in",
      "actions": [
        {
          "action_id": "match_student_mentor",
          "criteria": {
            "same_domain_interest": "primary",
            "timezone_overlap": "secondary",
            "mentor_availability": "required"
          },
          "algorithm": "round_robin_with_preference_weighting"
        },
        {
          "action_id": "schedule_weekly_office_hours",
          "duration_minutes": 30,
          "format": "optional_but_recommended",
          "calendar_integration": "google_calendar"
        },
        {
          "action_id": "send_intro_dm",
          "platforms": ["discord", "email"],
          "message": "Meet your mentor! {{mentor_name}} is here to help with {{domain}}.",
          "include": "mentor_bio_and_calendly_link"
        },
        {
          "action_id": "track_office_hours_attendance",
          "log_to": "mentor_productivity_dashboard"
        }
      ]
    },

    {
      "id": "trigger_capstone_project",
      "name": "Capstone Project Triggering & Tracking",
      "type": "time-based",
      "trigger_day": 67,
      "duration_days": 10,
      "actions": [
        {
          "action_id": "release_capstone_brief",
          "content": "Build 1 substantial project combining all skills from 76 days",
          "options": [
            "Full-stack web app + ML backend",
            "IoT project + cloud dashboard",
            "Freelance project for real client",
            "Open-ended (anything goes)"
          ]
        },
        {
          "action_id": "provide_capstone_resources",
          "include": [
            "project_template_github_repo",
            "deployment_checklist",
            "final_review_rubric",
            "example_capstone_projects"
          ]
        },
        {
          "action_id": "collect_capstone_submissions",
          "deadline": "day_76_11_59_pm",
          "required_deliverables": [
            "github_repo_link",
            "deployed_live_url",
            "5_min_demo_video",
            "reflection_essay_500_words"
          ]
        },
        {
          "action_id": "final_review_and_grading",
          "reviewers": "2_mentors_plus_1_peer",
          "rubric": "technical_quality, creativity, presentation, reflection"
        },
        {
          "action_id": "award_final_certificate",
          "certificate_type": "Industry-Ready Builder - S-KILLING IT Capstone",
          "include": "capstone_project_description, skills_list, mentor_recommendation"
        }
      ]
    }
  ],

  "database_schema": {
    "students_collection": {
      "fields": [
        "student_id",
        "email",
        "name",
        "cohort_number",
        "domain_interest",
        "timezone",
        "discord_username",
        "enrollment_date",
        "preferred_learning_time",
        "github_profile"
      ]
    },
    "progress_collection": {
      "fields": [
        "student_id",
        "day_number",
        "lesson_completed",
        "video_watched_percent",
        "project_submitted",
        "project_url",
        "completion_date",
        "time_spent_minutes"
      ]
    },
    "gamification_collection": {
      "fields": [
        "student_id",
        "total_xp_points",
        "current_streak_days",
        "longest_streak_days",
        "badges_earned",
        "quiz_scores",
        "weekly_rankings",
        "last_activity_date"
      ]
    },
    "projects_collection": {
      "fields": [
        "project_id",
        "student_id",
        "day_assigned",
        "github_url",
        "deployed_url",
        "peer_reviews",
        "final_score",
        "submission_date",
        "tags"
      ]
    },
    "quiz_collection": {
      "fields": [
        "quiz_id",
        "student_id",
        "week_number",
        "questions_answered",
        "score_percent",
        "time_taken_minutes",
        "submission_date",
        "retry_count",
        "unlocked_content"
      ]
    },
    "badges_collection": {
      "fields": [
        "badge_id",
        "student_id",
        "badge_name",
        "earned_date",
        "rarity",
        "image_url",
        "description"
      ]
    }
  },

  "notification_settings": {
    "channels": ["discord", "email", "whatsapp", "web_dashboard"],
    "frequency_rules": {
      "daily_lessons": "once_per_day_at_preferred_time",
      "reminders": "if_not_completed_after_12_hours",
      "achievements": "instant",
      "weekly_recap": "sunday_6pm",
      "leaderboard_updates": "daily_midnight",
      "quiz_availability": "friday_6pm"
    },
    "opt_out_option": "yes_but_track_engagement"
  },

  "success_metrics": {
    "7_day_sprint": {
      "lesson_completion_rate": "target_85_percent",
      "final_quiz_pass_rate": "target_80_percent",
      "project_deployment_rate": "target_100_percent",
      "social_share_rate": "target_50_percent"
    },
    "76_day_curriculum": {
      "overall_completion_rate": "target_60_percent",
      "average_quiz_score": "target_75_percent",
      "projects_completed_per_student": "target_12_plus",
      "first_freelance_gig_rate": "target_40_percent",
      "internship_interview_rate": "target_25_percent",
      "student_satisfaction": "target_4_5_out_of_5_stars"
    }
  },

  "budget_automation": {
    "content_creation": {
      "video_production": "76_videos × $200 = $15,200",
      "code_template_creation": "76_projects × $100 = $7,600",
      "quiz_creation": "11_weeks × 50_questions × $50 = $27,500"
    },
    "platform_costs": {
      "antigravity_automation": "$500/month = $5,500/year",
      "discord_server_hosting": "free_with_bot_upgrades_$20/month = $240/year",
      "email_service": "$300/month = $3,600/year",
      "database_storage": "$200/month = $2,400/year",
      "cdn_and_cdn": "$300/month = $3,600/year"
    },
    "total_first_year": "$65,640",
    "cost_per_student_at_10k_users": "$6.56",
    "monetization_option": "charge $49 for 76-day access = $490,000 revenue at breakeven, $434,360 profit"
  },

  "launch_checklist": {
    "pre_launch_week_1": [
      "Record all 76 video lessons",
      "Create all code templates and projects",
      "Build all 550+ quiz questions",
      "Set up Antigravity workflows (test 5x)",
      "Create 50+ badge graphics",
      "Configure Discord bot",
      "Set up leaderboard database",
      "Test email + SMS notification system",
      "Prepare GitHub organization with repos",
      "Write resource index document"
    ],
    "launch_day_1": [
      "Deploy Antigravity workflows to production",
      "Send onboarding emails to all signups",
      "Open Discord server to members",
      "Release Day 1 content (video + project brief)",
      "Initialize leaderboard",
      "Announce cohort on Twitter/LinkedIn",
      "Open support channels"
    ],
    "week_1_monitoring": [
      "Track 85%+ Day 1 completion rate",
      "Monitor Discord activity",
      "Respond to help requests within 2 hours",
      "Celebrate early wins publicly",
      "Fix any workflow bugs immediately"
    ],
    "week_2_transition": [
      "Grade all 7-day quizzes (48h turnaround)",
      "Unlock 76-day curriculum for qualifiers",
      "Send transition email",
      "Offer 1-on-1 calls for struggling students",
      "Announce top 10 from 7-day sprint"
    ]
  },

  "notes": {
    "philosophy": "This is not a course; it's a transformation. Every system is automated to maximize student learning and engagement while minimizing manual overhead.",
    "automation_level": "99% automation, 1% human touch (mentorship, office hours, capstone reviews)",
    "scaling": "Designed to handle 10,000+ students simultaneously with consistent quality",
    "competitive_advantage": "Combines industry-relevant content, gamification, community, and real projects into one automated ecosystem",
    "vision": "S-KILLING IT becomes the gold-standard post-secondary education platform for engineering students globally"
  }
}
